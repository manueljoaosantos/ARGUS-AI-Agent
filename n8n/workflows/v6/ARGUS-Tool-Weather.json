      "name": "extrair cidade"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const weather = $json.current_weather;\n\nreturn {\n  json: {\n    text: `Estão ${weather.temperature}°C com vento de ${weather.windspeed} km/h.`\n  }\n};"
      },
