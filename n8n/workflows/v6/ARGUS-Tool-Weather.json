    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json.input?.toLowerCase() || \"\";\n\nlet city = \"lisboa\";\n\nif (text.includes(\"porto\")) city = \"porto\";\nif (text.includes(\"lisboa\")) city = \"lisboa\";\nif (text.includes(\"braga\")) city = \"braga\";\n\nreturn {\n  json: {\n    city\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
