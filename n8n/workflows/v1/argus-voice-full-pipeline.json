    {
      "parameters": {
        "jsCode": "const inputs = $input.all();\n\n// separar inputs (Postgres)\nconst pg = inputs.find(i => i.json.messages !== undefined);\n\n// histórico vindo do PostgreSQL\nlet history = pg?.json?.messages || [];\n\n// garantir array\nif (typeof history === \"string\") {\n  try {\n    history = JSON.parse(history);\n  } catch {\n    history = [];\n  }\n}\n\n// 🔥 remover systems antigos (CRÍTICO)\nhistory = history.filter(m => m.role !== \"system\");\n\n// texto atual (STT)\nconst userText = $('STT (Whisper HTTP)').first().json.text || \"\";\n\n// DEBUG (opcional - podes ver se vem espanhol)\nconsole.log(\"STT TEXT:\", userText);\n\n// sessionId\nconst sessionId = $('Webhook').first().json.body.sessionId;\n\n// 🧠 system principal\nconst system = {\n  role: \"system\",\n  content: `\nÉs um assistente de voz que fala exclusivamente português de Portugal (PT-PT).\n\nResponde sempre em português europeu natural e nunca uses espanhol ou inglês.\n\nTens acesso ao histórico completo da conversa e deves utilizá-lo sempre.\n\nToda a informação fornecida anteriormente pelo utilizador (nome, preferências, contexto, respostas, etc.) é válida e deve ser considerada.\n\nNunca digas que não tens acesso a informações ou que não sabes algo se essa informação já foi fornecida nesta conversa.\n\nSe o utilizador fizer perguntas sobre algo já dito anteriormente, deves responder corretamente com base no histórico.\n\nMantém um tom natural, fluido e conversacional, usando linguagem simples e clara.\n\nUsa tratamento informal (tu), a menos que o utilizador indique o contrário.\n`\n};\n\n// 🔥 adicionar user UMA VEZ\nif (userText && userText.trim() !== \"\") {\n  history.push({\n    role: \"user\",\n    content: userText\n  });\n}\n\n// 🔥 reforço FINAL (super importante)\nconst languageGuard = {\n  role: \"system\",\n  content: \"IMPORTANTE: Responde sempre em português de Portugal. Nunca uses espanhol.\"\n};\n\n// 🔥 construir mensagens corretamente\nconst messages = [\n  system,\n  ...history,\n  languageGuard\n];\n\n// limitar histórico\nconst MAX_MESSAGES = 20;\n\nreturn [{\n  json: {\n    sessionId,\n    messages: messages.slice(-MAX_MESSAGES),\n    userText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1888,
        272
      ],
      "id": "d061d0f5-6781-4e24-8ad5-a5c504029552",
      "name": "Code (build messages)"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 🔥 buscar mensagens do node anterior (build messages)\nlet history = $('Code (build messages)').first().json.messages || [];\nconsole.log(\"HISTORY:\", history);\n// garantir array\nif (typeof history === \"string\") {\n  try {\n    history = JSON.parse(history);\n  } catch {\n    history = [];\n  }\n}\n\n// resposta do GPT\nconst response =\n  $json.choices?.[0]?.message?.content || \"\";\n\n// adicionar assistant\nhistory.push({\n  role: \"assistant\",\n  content: response\n});\n\nconst MAX_MESSAGES = 20;\n\nreturn {\n  json: {\n    sessionId: $('Webhook').first().json.body.sessionId,\n    messages: history.slice(-MAX_MESSAGES),\n    response\n  }\n};"
      },
