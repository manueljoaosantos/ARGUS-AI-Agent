      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO conversations (session_id, messages, updated_at)\nVALUES (\n  '{{$node[\"Webhook\"].json.body.sessionId}}',\n  '{{$json.messages.toJsonString()}}'::jsonb,\n  NOW()\n)\nON CONFLICT (session_id)\nDO UPDATE SET\n  messages = '{{$json.messages.toJsonString()}}'::jsonb,\n  updated_at = NOW();",
        "options": {}
